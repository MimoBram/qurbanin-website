<!DOCTYPE html>
<html lang="id">
<head>
  <title>QurbanIn - Home</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { font-family: 'Poppins', sans-serif; background:#fafafa; }
    .hero {
      min-height:100vh;
      background: linear-gradient(135deg,#2e7d32,#fbc02d);
      display:flex; align-items:center; justify-content:center;
      color:#fff; text-align:center; padding:0 20px;
    }
    .hero h1 { font-size:4rem; font-weight:800; }
    .hero p { font-size:1.5rem; margin-top:20px; opacity:0.9; }
    .btn-glow {
      background:#fff; color:#2e7d32; font-weight:600;
      padding:14px 32px; border-radius:40px;
      box-shadow:0 0 20px rgba(255,255,255,0.6);
      transition: all 0.3s ease;
    }
    .btn-glow:hover { transform:scale(1.05); box-shadow:0 0 30px rgba(255,255,255,0.9); }
    .features { display:flex; justify-content:center; gap:40px; margin-top:-80px; flex-wrap:wrap; }
    .feature {
      background: rgba(255,255,255,0.7); backdrop-filter: blur(12px);
      border-radius:20px; padding:40px; width:300px;
      box-shadow:0 8px 30px rgba(0,0,0,0.1); text-align:center;
      transition: transform 0.3s ease;
    }
    .feature:hover { transform: translateY(-10px); }
    .feature-icon { font-size:3rem; margin-bottom:20px; color:#2e7d32; }
    .story {
      padding:100px 20px; text-align:center;
      background: linear-gradient(135deg,#fffde7,#fbc02d);
    }
    .story h2 { font-weight:700; margin-bottom:20px; font-size:2.5rem; }
    .testimonial {
      background:#fff; border-radius:20px; padding:30px;
      box-shadow:0 6px 20px rgba(0,0,0,0.08); text-align:center;
      transition: transform 0.3s ease;
    }
    .testimonial:hover { transform:scale(1.03); }
    footer { background:#2e2e2e; color:#ccc; padding:40px; text-align:center; }
  </style>
</head>
<body>
  <%- include('./partials/navbar') %>

  <!-- Hero -->
  <section class="hero">
    <div>
      <h1>Berqurban Lebih Mudah & Bermakna</h1>
      <p>QurbanIn hadir dengan pengalaman modern, transparan, dan penuh makna.</p>
      <a href="/animals" class="btn-glow mt-4">🌟 Lihat Katalog Hewan</a>
    </div>
  </section>

  <!-- Features -->
  <section class="features container py-5">
    <div class="feature">
      <div class="feature-icon">🐑</div>
      <h3>Hewan Sehat</h3>
      <p>Diperiksa dan dijamin sesuai syariat.</p>
    </div>
    <div class="feature">
      <div class="feature-icon">💳</div>
      <h3>Pembayaran Aman</h3>
      <p>Berbagai metode pembayaran terpercaya.</p>
    </div>
    <div class="feature">
      <div class="feature-icon">📦</div>
      <h3>Pengantaran Tepat Waktu</h3>
      <p>Hewan diantar sesuai jadwal yang kamu tentukan.</p>
    </div>
  </section>

  <!-- Storytelling -->
  <section class="story">
    <h2>Qurban adalah Ibadah & Dukungan Sosial</h2>
    <p>Setiap transaksi di QurbanIn membantu peternak lokal dan memperkuat ekonomi umat.</p>
  </section>

  <!-- Testimonials -->
  <section class="container py-5">
    <h2 class="text-center mb-5 fw-bold">Apa Kata Mereka?</h2>
    <div class="row g-4">
      <div class="col-md-4"><div class="testimonial">"Prosesnya gampang banget, hewan sehat dan sesuai janji." <br><small>- Ahmad</small></div></div>
      <div class="col-md-4"><div class="testimonial">"Saya bisa pesan dari rumah, transparan dan aman." <br><small>- Siti</small></div></div>
      <div class="col-md-4"><div class="testimonial">"Pengantaran tepat waktu, sangat membantu." <br><small>- Budi</small></div></div>
    </div>
  </section>

  <!-- CTA -->
  <section class="text-center py-5" style="background:#2e7d32;color:#fff;">
    <h2 class="fw-bold">Siap Berqurban Tahun Ini?</h2>
    <% if (user) { %>
      <a href="/orders" class="btn btn-warning btn-lg mt-3">Pesan Sekarang</a>
    <% } else { %>
      <a href="/login" class="btn btn-light btn-lg mt-3">Login untuk Memesan</a>
    <% } %>
  </section>

  <!-- Footer -->
  <footer>
    <p>&copy; 2026 QurbanIn. All rights reserved.</p>
  </footer>
</body>
</html>