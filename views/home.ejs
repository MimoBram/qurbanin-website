<!DOCTYPE html>
<html lang="id">
<head><%- include('./partials/head') %></head>
<body>
  <%- include('./partials/navbar') %>

  <div class="container" style="padding-top:40px;padding-bottom:60px">

    <!-- Hero -->
    <div style="background:#F0FAF5;border-radius:20px;padding:48px 44px;display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:center;border:0.5px solid #C8E8D8;position:relative;overflow:hidden;margin-bottom:48px">
      <div style="position:absolute;top:-80px;right:-80px;width:280px;height:280px;border-radius:50%;background:rgba(30,140,90,0.06)"></div>
      <div style="position:absolute;bottom:-60px;left:30%;width:180px;height:180px;border-radius:50%;background:rgba(245,166,35,0.05)"></div>

      <div style="position:relative;z-index:1">
        <div style="display:inline-flex;align-items:center;gap:6px;background:#FFF4E0;color:#C47D10;font-size:11px;font-weight:600;padding:5px 12px;border-radius:20px;margin-bottom:16px">✦ Idul Adha 1446H</div>
        <h1 style="font-size:34px;font-weight:800;color:var(--text);line-height:1.2;letter-spacing:-0.03em;margin-bottom:14px">Hewan Kurban <span style="color:var(--primary)">Terbaik</span>,<br>Langsung dari<br>Peternak Lokal</h1>
        <p style="font-size:13px;color:var(--muted);line-height:1.75;margin-bottom:26px;max-width:300px">Pilih hewan kurbanmu dengan mudah. Transparan, terpercaya, dan dikirim langsung dari peternak terverifikasi.</p>
        <div style="display:flex;gap:10px">
          <a href="/animals" class="btn-primary">Lihat Katalog →</a>
          <a href="/register" class="btn-outline">Daftar Sekarang</a>
        </div>
      </div>

      <div style="display:flex;align-items:center;justify-content:center;position:relative;z-index:1">
        <div style="position:relative;width:100%;height:260px;display:flex;align-items:center;justify-content:center">
          <div style="position:absolute;width:200px;height:200px;border-radius:50%;background:rgba(30,140,90,0.08)"></div>
          <div style="position:absolute;bottom:20px;left:10%;right:10%;height:18px;background:rgba(30,140,90,0.1);border-radius:50%"></div>
          <svg width="180" height="180" viewBox="0 0 180 180" fill="none" xmlns="http://www.w3.org/2000/svg" style="position:relative;z-index:2">
            <ellipse cx="90" cy="162" rx="48" ry="8" fill="rgba(30,140,90,0.12)"/>
            <ellipse cx="90" cy="115" rx="52" ry="36" fill="#fff" stroke="#C8E8D8" stroke-width="1.5"/>
            <ellipse cx="78" cy="110" rx="12" ry="9" fill="#C8EDD8" opacity="0.6"/>
            <ellipse cx="105" cy="120" rx="9" ry="7" fill="#C8EDD8" opacity="0.6"/>
            <rect x="62" y="142" width="11" height="22" rx="5" fill="#fff" stroke="#C8E8D8" stroke-width="1.5"/>
            <rect x="78" y="145" width="11" height="19" rx="5" fill="#fff" stroke="#C8E8D8" stroke-width="1.5"/>
            <rect x="97" y="145" width="11" height="19" rx="5" fill="#fff" stroke="#C8E8D8" stroke-width="1.5"/>
            <rect x="113" y="142" width="11" height="22" rx="5" fill="#fff" stroke="#C8E8D8" stroke-width="1.5"/>
            <rect x="62" y="158" width="11" height="7" rx="3" fill="#A8D0B8"/>
            <rect x="78" y="158" width="11" height="7" rx="3" fill="#A8D0B8"/>
            <rect x="97" y="158" width="11" height="7" rx="3" fill="#A8D0B8"/>
            <rect x="113" y="158" width="11" height="7" rx="3" fill="#A8D0B8"/>
            <path d="M90 85 Q82 95 80 110" stroke="#C8E8D8" stroke-width="18" stroke-linecap="round" fill="none"/>
            <path d="M90 85 Q82 95 80 110" stroke="#fff" stroke-width="14" stroke-linecap="round" fill="none"/>
            <ellipse cx="85" cy="76" rx="26" ry="22" fill="#fff" stroke="#C8E8D8" stroke-width="1.5"/>
            <ellipse cx="62" cy="68" rx="8" ry="5" fill="#fff" stroke="#C8E8D8" stroke-width="1.5" transform="rotate(-20 62 68)"/>
            <ellipse cx="108" cy="68" rx="8" ry="5" fill="#fff" stroke="#C8E8D8" stroke-width="1.5" transform="rotate(20 108 68)"/>
            <ellipse cx="62" cy="68" rx="5" ry="3" fill="#FFD4D4" transform="rotate(-20 62 68)"/>
            <ellipse cx="108" cy="68" rx="5" ry="3" fill="#FFD4D4" transform="rotate(20 108 68)"/>
            <path d="M68 58 Q60 44 56 40" stroke="#C8A96E" stroke-width="3" stroke-linecap="round" fill="none"/>
            <path d="M102 58 Q110 44 114 40" stroke="#C8A96E" stroke-width="3" stroke-linecap="round" fill="none"/>
            <circle cx="77" cy="73" r="4" fill="#1A2E22"/>
            <circle cx="93" cy="73" r="4" fill="#1A2E22"/>
            <circle cx="78.5" cy="71.5" r="1.5" fill="#fff"/>
            <circle cx="94.5" cy="71.5" r="1.5" fill="#fff"/>
            <ellipse cx="85" cy="84" rx="10" ry="7" fill="#FFE4E4"/>
            <circle cx="81" cy="84" r="2.5" fill="#E8A0A0"/>
            <circle cx="89" cy="84" r="2.5" fill="#E8A0A0"/>
