<!DOCTYPE html>
<html lang="id">
<head><%- include('../partials/head') %></head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container" style="padding-top:40px;padding-bottom:60px;max-width:700px">

    <div class="page-header">
      <h1>Profil Saya</h1>
      <p>Informasi akun dan data diri kamu</p>
    </div>

    <!-- Avatar + Info Utama -->
    <div class="card" style="padding:28px;margin-bottom:16px;display:flex;align-items:center;gap:20px">
      <div style="width:64px;height:64px;border-radius:50%;background:var(--primary-light);border:2px solid var(--primary-border);display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0">
        <%= user.role === 'admin' ? '🛡️' : user.role === 'farmer' || user.role === 'peternak' ? '🌾' : '👤' %>
      </div>
      <div style="flex:1">
        <div style="font-size:18px;font-weight:800;letter-spacing:-0.02em;margin-bottom:4px">
          <%= user.UserProfile ? user.UserProfile.fullName : user.email %>
        </div>
        <div style="font-size:13px;color:var(--muted)"><%= user.email %></div>
        <div style="margin-top:8px">
          <span class="badge" style="background:var(--primary-light);color:var(--primary);font-size:11px">
            <%= user.role === 'pembeli' ? '🛒 Pembeli' : user.role === 'farmer' || user.role === 'peternak' ? '🌾 Peternak' : '🛡️ Admin' %>
          </span>
        </div>
      </div>
    </div>

    <!-- Data Diri -->
    <div class="card" style="padding:28px;margin-bottom:16px">
      <div style="font-size:11px;font-weight:600;color:var(--muted);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:16px">Data Diri</div>

      <% if (user.UserProfile) { %>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
          <div>
            <div style="font-size:11px;color:var(--muted);margin-bottom:4px">Nama Lengkap</div>
            <div style="font-size:14px;font-weight:600"><%= user.UserProfile.fullName || '-' %></div>
          </div>
          <div>
            <div style="font-size:11px;color:var(--muted);margin-bottom:4px">Email</div>
            <div style="font-size:14px;font-weight:600"><%= user.email %></div>
          </div>
          <div>
            <div style="font-size:11px;color:var(--muted);margin-bottom:4px">Nomor Telepon</div>
            <div style="font-size:14px;font-weight:600"><%= user.UserProfile.phone || '-' %></div>
          </div>
          <div>
            <div style="font-size:11px;color:var(--muted);margin-bottom:4px">Alamat</div>
            <div style="font-size:14px;font-weight:600"><%= user.UserProfile.address || '-' %></div>
          </div>
        </div>
      <% } else { %>
        <div style="text-align:center;padding:20px 0;color:var(--muted)">
          <div style="font-size:32px;margin-bottom:8px">📋</div>
          <p style="font-size:13px">Belum ada data profil.</p>
        </div>
      <% } %>
    </div>

    <!-- Edit Profil Form -->
    <div class="card" style="padding:28px;margin-bottom:16px">
      <div style="font-size:11px;font-weight:600;color:var(--muted);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:16px">Edit Profil</div>

      <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
        <div class="error-list">
          <% errors.forEach(e => { %><p>⚠ <%= e.message || e %></p><% }) %>
        </div>
      <% } %>

      <form action="/profile" method="POST">
        <div class="form-group">
          <label>Nama Lengkap</label>
          <input type="text" name="fullName" placeholder="Nama lengkap kamu" value="<%= user.UserProfile ? user.UserProfile.fullName || '' : '' %>">
        </div>
        <div class="form-group">
          <label>Nomor Telepon</label>
          <input type="text" name="phone" placeholder="08xxxxxxxxxx" value="<%= user.UserProfile ? user.UserProfile.phone || '' : '' %>">
        </div>
        <div class="form-group">
          <label>Alamat Pengiriman</label>
          <input type="text" name="address" placeholder="Alamat lengkap kamu" value="<%= user.UserProfile ? user.UserProfile.address || '' : '' %>">
        </div>
        <button type="submit" class="btn-primary" style="width:100%;padding:11px;font-size:14px">Simpan Perubahan</button>
      </form>
    </div>

    <!-- Aksi Akun -->
    <div class="card" style="padding:20px;display:flex;justify-content:space-between;align-items:center">
      <div>
        <div style="font-size:14px;font-weight:600">Keluar dari Akun</div>
        <div style="font-size:12px;color:var(--muted);margin-top:2px">Sesi kamu akan diakhiri</div>
      </div>
      <form action="/logout" method="POST" style="margin:0">
        <button type="submit" class="btn-danger" style="padding:8px 20px">Keluar</button>
      </form>
    </div>

  </div>
</body>
</html>