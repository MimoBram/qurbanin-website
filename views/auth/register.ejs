<!DOCTYPE html>
<html lang="id">
<head><%- include('../partials/head') %></head>
<body>
  <%- include('../partials/navbar') %>
  <div class="container" style="padding-top:60px;padding-bottom:60px;max-width:440px">
    <div style="text-align:center;margin-bottom:28px">
      <h1 style="font-size:26px;font-weight:800;letter-spacing:-0.02em;margin-bottom:6px">Buat Akun</h1>
      <p style="font-size:13px;color:var(--muted)">Bergabung dengan QurbanIn sekarang</p>
    </div>
    <div class="card" style="padding:32px">
      <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
        <div class="error-list">
          <% errors.forEach(e => { %><p>⚠ <%= e %></p><% }) %>
        </div>
      <% } %>
      <form action="/register" method="POST">
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" placeholder="email@kamu.com" required>
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" name="password" placeholder="Min. 8 karakter" required>
        </div>
        <div class="form-group">
          <label>Daftar sebagai</label>
          <select name="role">
            <option value="buyer">Pembeli</option>
            <option value="farmer">Peternak</option>
          </select>
        </div>
        <button type="submit" class="btn-primary" style="width:100%;padding:11px;font-size:14px">Daftar Gratis</button>
      </form>
      <p style="text-align:center;margin-top:20px;font-size:13px;color:var(--muted)">
        Sudah punya akun? <a href="/login" style="color:var(--primary);font-weight:600">Masuk di sini</a>
      </p>
    </div>
  </div>
</body>
</html>