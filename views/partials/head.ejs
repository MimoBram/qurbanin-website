<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QurbanIn</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --primary: #1E8C5A;
    --primary-light: #E8F7F0;
    --primary-border: #C8E8D8;
    --accent: #F5A623;
    --accent-light: #FFF4E0;
    --bg: #F7FBF9;
    --text: #1A2E22;
    --muted: #6B8F78;
    --white: #ffffff;
    --font: 'Plus Jakarta Sans', sans-serif;
    --radius: 12px;
    --shadow: 0 4px 20px rgba(30,140,90,0.08);
  }
  body { font-family: var(--font); background: var(--bg); color: var(--text); min-height: 100vh; }
  a { text-decoration: none; color: inherit; }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

  /* NAVBAR */
  .navbar { background: var(--white); border-bottom: 0.5px solid var(--primary-border); height: 64px; display: flex; align-items: center; position: sticky; top: 0; z-index: 100; }
  .navbar .container { display: flex; align-items: center; justify-content: space-between; width: 100%; }
  .nav-brand { font-size: 20px; font-weight: 800; color: var(--text); letter-spacing: -0.02em; }
  .nav-brand span { color: var(--primary); }
  .nav-brand sup { font-size: 8px; background: var(--accent); color: #fff; padding: 2px 5px; border-radius: 4px; font-weight: 600; vertical-align: top; margin-top: 4px; margin-left: 2px; }
  .nav-links { display: flex; gap: 2px; align-items: center; }
  .nav-links a { font-size: 13px; color: var(--muted); padding: 6px 14px; border-radius: 8px; font-weight: 500; transition: all 0.15s; }
  .nav-links a:hover, .nav-links a.active { color: var(--primary); background: var(--primary-light); }
  .nav-actions { display: flex; gap: 8px; align-items: center; }

  /* BUTTONS */
  .btn-primary { font-size: 13px; color: #fff; background: var(--primary); border: none; padding: 8px 20px; border-radius: 8px; cursor: pointer; font-weight: 600; font-family: var(--font); transition: background 0.15s; display: inline-block; }
  .btn-primary:hover { background: #176b45; }
  .btn-outline { font-size: 13px; color: var(--primary); background: var(--white); border: 1.5px solid var(--primary); padding: 7px 20px; border-radius: 8px; cursor: pointer; font-weight: 500; font-family: var(--font); transition: all 0.15s; display: inline-block; }
  .btn-outline:hover { background: var(--primary-light); }
  .btn-danger { font-size: 13px; color: #fff; background: #E53E3E; border: none; padding: 8px 20px; border-radius: 8px; cursor: pointer; font-weight: 600; font-family: var(--font); display: inline-block; }

  /* CARDS */
  .card { background: var(--white); border: 0.5px solid var(--primary-border); border-radius: var(--radius); overflow: hidden; transition: box-shadow 0.2s; }
  .card:hover { box-shadow: var(--shadow); }

  /* FORM */
  .form-group { margin-bottom: 16px; }
  .form-group label { display: block; font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 6px; }
  .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 10px 14px; border: 1.5px solid var(--primary-border); border-radius: 8px; font-size: 13px; font-family: var(--font); color: var(--text); background: var(--white); outline: none; transition: border-color 0.15s; }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--primary); }

  /* ERROR */
  .error-list { background: #FFF5F5; border: 1px solid #FED7D7; border-radius: 8px; padding: 12px 16px; margin-bottom: 16px; }
  .error-list p { font-size: 13px; color: #E53E3E; margin-bottom: 4px; }
  .error-list p:last-child { margin-bottom: 0; }

  /* BADGE */
  .badge { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; display: inline-block; }
  .badge-sapi { background: #C8EDD8; color: #1A6640; }
  .badge-kambing { background: #FFE4B0; color: #9A5C00; }
  .badge-domba { background: #D8E0FF; color: #3344AA; }
  .badge-tersedia { background: #C8EDD8; color: #1A6640; }
  .badge-terjual { background: #FFE4B0; color: #9A5C00; }
  .badge-pending { background: #FFF4E0; color: #C47D10; }
  .badge-confirmed { background: #C8EDD8; color: #1A6640; }
  .badge-cancelled { background: #FFE4E4; color: #C53030; }

  /* PAGE HEADER */
  .page-header { margin-bottom: 28px; }
  .page-header h1 { font-size: 26px; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 4px; }
  .page-header p { font-size: 13px; color: var(--muted); }

  /* EMPTY STATE */
  .empty-state { text-align: center; padding: 60px 24px; color: var(--muted); }
  .empty-state .empty-icon { font-size: 48px; margin-bottom: 12px; }
  .empty-state p { font-size: 14px; }
</style>