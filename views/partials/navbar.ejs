<nav class="navbar">
  <div class="container">
    <a href="/home" class="nav-brand">Qurban<span>In</span><sup>✦</sup></a>
    <div class="nav-links">
      <a href="/animals">Katalog</a>

      <% if (typeof user !== 'undefined' && user) { %>
        <% if (user.role === 'admin') { %>
          <a href="/farms">Farms</a>
          <a href="/orders">Pesanan</a>
        <% } else if (user.role === 'farmer' || user.role === 'peternak') { %>
          <a href="/farms">Kandang Saya</a>
          <a href="/orders">Pesanan</a>
        <% } else { %>
          <a href="/orders">Pesanan Saya</a>
        <% } %>
        <a href="/profile">Profil</a>
      <% } %>
    </div>
    <div class="nav-actions">
      <% if (typeof user !== 'undefined' && user) { %>
        <div style="display:flex;align-items:center;gap:6px;background:var(--primary-light);border:1px solid var(--primary-border);padding:6px 12px;border-radius:8px;font-size:12px;font-weight:500;color:var(--primary)">
          <%= user.role === 'admin' ? '🛡️' : user.role === 'farmer' || user.role === 'peternak' ? '🌾' : '🛒' %>
          <%= user.email %>
          <a href=""></a>
        </div>
        <form action="/logout" method="POST" style="margin:0">
          <button type="submit" class="btn-primary">Keluar</button>
        </form>
      <% } else { %>
        <a href="/login" class="btn-outline">Masuk</a>
        <a href="/register" class="btn-primary">Daftar Gratis</a>
      <% } %>
    </div>
  </div>
</nav>