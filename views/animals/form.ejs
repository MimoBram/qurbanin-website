<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container" style="padding:40px 0;">
    <div class="page-header">
      <h1><%= mode === 'edit' ? 'Edit Hewan' : 'Tambah Hewan' %></h1>
      <p><%= mode === 'edit' ? 'Ubah data hewan qurban' : 'Masukkan data hewan baru' %></p>
    </div>

    <% if (errors && errors.length > 0) { %>
      <div class="error-list">
        <% errors.forEach(err => { %>
          <p><%= err.message %></p>
        <% }) %>
      </div>
    <% } %>

    <form action="<%= mode === 'edit' ? '/animals/' + animal.id + '/edit' : '/animals/add' %>" method="POST" class="card" style="padding:32px;">
      <div class="form-group">
        <label>Nama Hewan</label>
        <input type="text" name="name" value="<%= animal ? animal.name : '' %>" required>
      </div>

      <div class="form-group">
        <label>Jenis</label>
        <select name="type" required>
          <option value="sapi" <%= animal && animal.type === 'sapi' ? 'selected' : '' %>>Sapi</option>
          <option value="kambing" <%= animal && animal.type === 'kambing' ? 'selected' : '' %>>Kambing</option>
          <option value="domba" <%= animal && animal.type === 'domba' ? 'selected' : '' %>>Domba</option>
        </select>
      </div>

      <div class="form-group">
        <label>Berat (kg)</label>
        <input type="number" name="weight" value="<%= animal ? animal.weight : '' %>" required>
      </div>

      <div class="form-group">
        <label>Usia (tahun)</label>
        <input type="number" name="age" value="<%= animal ? animal.age : '' %>" required>
      </div>

      <div class="form-group">
        <label>Harga (Rp)</label>
        <input type="number" name="price" value="<%= animal ? animal.price : '' %>" required>
      </div>

      <div class="form-group">
        <label>Kandang</label>
        <select name="farmId" required>
          <% farms.forEach(farm => { %>
            <option value="<%= farm.id %>" <%= animal && animal.farmId === farm.id ? 'selected' : '' %>><%= farm.name %></option>
          <% }) %>
        </select>
      </div>

      <div style="display:flex; gap:12px; margin-top:20px;">
        <button type="submit" class="btn-primary"><%= mode === 'edit' ? 'Update Hewan' : 'Simpan Hewan' %></button>
        <a href="/animals" class="btn-outline">Batal</a>
      </div>
    </form>
  </div>
</body>
</html>