<div class="container">
  <div class="page-header">
    <h1><%= mode === 'edit' ? 'Edit Kandang' : 'Tambah Kandang' %></h1>
  </div>

  <form action="<%= mode === 'edit' ? '/farms/' + farm.id + '/edit' : '/farms/add' %>" method="POST" class="card" style="padding:32px;">
    <div class="form-group">
      <label>Nama Kandang</label>
      <input type="text" name="name" value="<%= farm ? farm.name : '' %>" required>
    </div>
    <div class="form-group">
      <label>Lokasi</label>
      <input type="text" name="location" value="<%= farm ? farm.location : '' %>" required>
    </div>
    <div style="display:flex; gap:12px; margin-top:20px;">
      <button type="submit" class="btn-primary"><%= mode === 'edit' ? 'Update' : 'Simpan' %></button>
      <a href="/farms" class="btn-outline">Batal</a>
    </div>
  </form>
</div>
